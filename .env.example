# NEXTAUTH CẤU HÌNH (NextAuth.js cho xác thực - ở đây dùng custom session nhưng vẫn cần secret)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=appsheet_print_hub_secret_key_2024

# GOOGLE OAUTH CREDENTIALS (Lấy từ Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GOOGLE RESOURCES (ID từ URL của Sheet và Folder Drive)
GOOGLE_SHEET_ID=
GOOGLE_DRIVE_FOLDER_TEMPLATE=
GOOGLE_DRIVE_FOLDER_OUTPUT=

# URL ỨNG DỤNG (Dùng cho redirect OAuth - Quan trọng khi deploy Vercel)
# Ví dụ: https://ten-app-cua-ban.vercel.app
APP_URL=http://localhost:3000

# CẤU HÌNH MÔI TRƯỜNG
NODE_ENV=development
